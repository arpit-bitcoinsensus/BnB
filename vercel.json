{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/config",
      "destination": "/api/config.js"
    },
    {
      "source": "/shopify-api/(.*)",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/shopify-dashboard.html"
    }
  ]
}
